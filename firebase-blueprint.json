{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "department": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["id", "name", "email", "department", "role"]
    },
    "Connector": {
      "title": "Connector",
      "description": "A system connector for identity or data layers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["identity", "data"] },
        "status": { "type": "string", "enum": ["active", "inactive", "error"] },
        "lastSync": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "type", "status", "lastSync"]
    },
    "AccessReview": {
      "title": "AccessReview",
      "description": "A record of a user's access to a resource for auditing.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string", "format": "email" },
        "connectorId": { "type": "string" },
        "connectorName": { "type": "string" },
        "resource": { "type": "string" },
        "permission": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "flagged", "revoked"] },
        "aiRecommendation": { "type": "string" },
        "aiConfidence": { "type": "number" },
        "lastReviewedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "userName", "userEmail", "connectorId", "connectorName", "resource", "permission", "status"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "A log of system or administrative actions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "action": { "type": "string" },
        "user": { "type": "string" },
        "details": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "critical"] }
      },
      "required": ["id", "timestamp", "action", "user", "details", "severity"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/connectors/{connectorId}": {
      "schema": "Connector",
      "description": "System connectors."
    },
    "/reviews/{reviewId}": {
      "schema": "AccessReview",
      "description": "Access review records."
    },
    "/logs/{logId}": {
      "schema": "AuditLog",
      "description": "Audit logs."
    }
  }
}
